# Public-safe example environment for an automation stack.
# Copy to .env and replace placeholder values before real deployment.

POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace_with_strong_password
POSTGRES_DB=n8n

BROWSERLESS_MAX_CONCURRENT_SESSIONS=10
BROWSERLESS_TOKEN=replace_with_browserless_token

N8N_HOST=automation.example.internal
WEBHOOK_URL=https://automation.example.internal/
N8N_SECURE_COOKIE=true
GENERIC_TIMEZONE=Europe/Warsaw
TZ=Europe/Warsaw

# Optional APIs and integrations
QDRANT_API_KEY=replace_with_qdrant_api_key
N8N_API_KEY=replace_with_n8n_api_key

# Optional chat integrations
MATTERMOST_WEBHOOK_URL=https://chat.example.internal/hooks/replace_me
MATTERMOST_DEFAULT_CHANNEL=
MATTERMOST_DEFAULT_USERNAME=
MATTERMOST_DEFAULT_ICON_URL=https://assets.example.internal/icon.png

RC_API_TOKEN=replace_with_rocketchat_token
RC_API_USER_ID=replace_with_rocketchat_user_id

# Optional feature flags
N8N_COMMUNITY_PACKAGES_ENABLED=true
N8N_COMMUNITY_PACKAGES_ALLOW_TOOL_USAGE=true

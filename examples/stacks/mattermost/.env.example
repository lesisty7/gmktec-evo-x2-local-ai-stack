# Public-safe example environment for a Mattermost stack.
# Copy to .env and replace placeholder values before real deployment.

# Database
MATTERMOST_DB_USER=mattermost
MATTERMOST_DB_PASSWORD=replace_with_strong_db_password

# URLs
MATTERMOST_SITE_URL=https://chat.example.internal
MATTERMOST_BASE_URL=http://mattermost:8065

# Bootstrap admin
MATTERMOST_ADMIN_USERNAME=admin
MATTERMOST_ADMIN_EMAIL=admin@example.internal
MATTERMOST_ADMIN_PASSWORD=replace_with_strong_admin_password

# Timezone and paths
MATTERMOST_TZ=Europe/Warsaw
MATTERMOST_DB_PATH=/mnt/containers/mattermost-db
MATTERMOST_DATA_PATH=/mnt/containers/mattermost-data
MATTERMOST_BACKUP_PATH=/mnt/containers/mattermost-backup
MATTERMOST_BACKUP_INTERVAL=172800

# Bootstrap content
MATTERMOST_TEAM_NAME=team
MATTERMOST_TEAM_DISPLAY_NAME=Team
MATTERMOST_CHANNEL_NAME=automation
MATTERMOST_CHANNEL_DISPLAY_NAME=automation
MATTERMOST_WEBHOOK_NAME=automation-webhook

# Bootstrap toggles
MATTERMOST_ENABLE_TEAM_CREATION=false
MATTERMOST_ENABLE_USER_CREATION=false
MATTERMOST_ENABLE_SIGNUP_EMAIL=false
MATTERMOST_ENABLE_EMAIL_NOTIFICATIONS=true

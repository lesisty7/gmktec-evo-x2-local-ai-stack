# Public-safe example environment for a Qdrant stack.
# Copy to .env and replace placeholder values for your environment.

# Network ports
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_ALLOW_RECOVERY_MODE=true
QDRANT__TELEMETRY__DISABLED=true

# Host paths
QDRANT_STORAGE_DIR=/mnt/containers/qdrant-data
QDRANT_BACKUP_DIR=/mnt/containers/qdrant-backup

# Auth
QDRANT_API_KEY=replace_with_qdrant_api_key
QDRANT_REMOTE_API_KEY=replace_with_remote_qdrant_api_key

# Backup settings
QDRANT_COLLECTION=knowledge_base
QDRANT_URL=http://qdrant:6333
QDRANT_REMOTE_URL=https://qdrant-remote.example.internal:6333
BACKUP_CRON=0 2 * * *
DOCKER_NETWORK_NAME=ai-net

# Init helper
QDRANT_INIT_FILE=./qdrant-init-knowledge_base.json

# Public-safe example environment for a Rocket.Chat stack.
# Copy to .env and replace placeholder values before real deployment.

# Network
AI_NET_NAME=ai-net

# Images
RC_IMAGE=registry.rocket.chat/rocketchat/rocket.chat:latest
MONGO_IMAGE=mongo:8.2

# Container names
ROCKETCHAT_CONTAINER_NAME=rocketchat
MONGO_CONTAINER_NAME=rocketchat-mongo
MONGO_INIT_CONTAINER_NAME=rocketchat-mongo-init

# Rocket.Chat
ROCKETCHAT_HOST_PORT=3002
ROCKETCHAT_INTERNAL_PORT=3000
ROOT_URL=https://chat.example.internal
ROCKETCHAT_UPLOADS_DIR=/mnt/containers/rocketchat-uploads

# MongoDB
MONGO_HOST=rocketchat-mongo
MONGO_PORT=27017
MONGO_REPLSET=rs0
MONGO_OPLOG_SIZE=128
MONGO_STORAGE_ENGINE=wiredTiger
MONGO_DB=rocketchat
MONGO_DATA_DIR=/mnt/containers/rocketchat-mongo

# SMTP
MAIL_URL=smtps://smtp-user:replace_with_smtp_password@smtp.example.internal:465/

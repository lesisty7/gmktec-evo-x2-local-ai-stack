OPENWEBUI_DATA_DIR=/mnt/containers/open-webui-data
PIPELINES_DATA_DIR=/mnt/containers/pipelines-data

WEBUI_NAME=Local AI Workbench
DEFAULT_USER_ROLE=user
ENABLE_SIGNUP=false

OPENWEBUI_HOST_PORT=3000
PIPELINES_HOST_PORT=9099
TIKA_HOST_PORT=9998

OPENAI_API_BASE_URL=http://host.docker.internal:11434/v1
OPENAI_API_KEY=replace_with_non_empty_placeholder
OPENAI_API_BASE_URLS=http://host.docker.internal:11434/v1;http://pipelines:9099
OPENAI_API_KEYS=replace_with_non_empty_placeholder;replace_with_pipeline_api_key
PIPELINES_API_KEY=replace_with_pipeline_api_key

AUDIO_OPENAI_API_BASE_URL=http://speaches:8000/v1
AUDIO_OPENAI_API_KEY=replace_with_non_empty_placeholder
AUDIO_AUTOPLAY=false

ENABLE_RAG_WEB_SEARCH=true
RAG_WEB_SEARCH_ENGINE=searxng
RAG_WEB_SEARCH_RESULT_COUNT=5
SEARXNG_QUERY_URL=http://searxng:8080/search?q=<query>
ENABLE_RAG_YOUTUBE_LOADER=true

ENABLE_IMAGE_GENERATION=true
IMAGE_GENERATION_ENGINE=comfyui
COMFYUI_BASE_URL=http://comfyui:8188/

CONTENT_EXTRACTION_ENGINE=tika
TIKA_SERVER_URL=http://tika:9998
ENABLE_CODE_EXECUTION=true

DOCKER_NETWORK_NAME=ai-net

# Public-safe example environment for the media stack.
# Copy to .env and adjust paths, ports, and image tags for your own machine.

COMFYUI_IMAGE=ghcr.io/pccr10001/comfyui-gfx1151-fa:260109
COMFYUI_CONTAINER_NAME=comfyui
COMFYUI_IDLE_UNLOADER_CONTAINER_NAME=comfyui-idle-unloader
COMFYUI_PORT=8188
COMFYUI_SHM_SIZE=8G
COMFYUI_ARGS=--listen 0.0.0.0 --gpu-only

COMFYUI_DATA_ROOT=/mnt/containers/comfyui-data
SD_MODELS_ROOT=/mnt/ai-models/sd

IDLE_SECONDS=900
POLL_SECONDS=15
FREE_COOLDOWN_SECONDS=300
FREE_UNLOAD_MODELS=true
FREE_MEMORY=true
STARTUP_WAIT_SECONDS=900
LOG_MODE=quiet

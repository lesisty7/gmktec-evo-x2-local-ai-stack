# Public-safe example environment for an MCP Playwright service.

MCP_PLAYWRIGHT_PORT=8931
MCP_PLAYWRIGHT_HOST=0.0.0.0
MCP_PLAYWRIGHT_DATA_DIR=/mnt/containers/playwright-mcp-data
MCP_PLAYWRIGHT_BROWSERS_DIR=/mnt/containers/playwright-mcp-browsers
DOCKER_NETWORK_NAME=ai-net
PLAYWRIGHT_MCP_ALLOWED_HOSTS=playwright-mcp,localhost,127.0.0.1,automation

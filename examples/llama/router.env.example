# Public-safe example generated from a private router-mode setup

# Hardware / ROCm
ROCM_PATH=/opt/rocm
HIP_PATH=/opt/rocm
HSA_OVERRIDE_GFX_VERSION=11.0.1
ROCR_VISIBLE_DEVICES=0
LD_LIBRARY_PATH=/opt/rocm/lib:${LD_LIBRARY_PATH}
PATH=/opt/rocm/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# Caches
LLAMA_CACHE=/mnt/ai-models/cache/llama.cpp
HF_HOME=/mnt/ai-models/cache/hf
HUGGINGFACE_HUB_CACHE=/mnt/ai-models/cache/hf/hub
TRANSFORMERS_CACHE=/mnt/ai-models/cache/hf/transformers

# Router configuration
LLAMA_HOST=0.0.0.0
LLAMA_PORT=11434
LLAMA_MODELS_DIR=/mnt/ai-models/llm
LLAMA_MODELS_MAX=1
LLAMA_CTX=32768
LLAMA_NGL=999

# Binary
LLAMA_SERVER_BIN=/opt/llama.cpp/build-hip/bin/llama-server


# Public-safe example generated from a private router-mode setup

# GPU runtime / fallback environment
ROCM_PATH=/opt/rocm
HIP_PATH=/opt/rocm
# Current public default is Vulkan. The fallback override below is kept because
# it helped stabilize router startup while HIP/ROCm was being debugged.
# These ROCm-related paths are still kept in the example because the same host
# may be re-tested on HIP/ROCm later, and llama.cpp server env parsing also
# uses related runtime variables even when Vulkan is the active backend.
HSA_OVERRIDE_GFX_VERSION=11.5.1
ROCR_VISIBLE_DEVICES=0
LD_LIBRARY_PATH=/opt/rocm/lib:${LD_LIBRARY_PATH}
PATH=/opt/rocm/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
# The current server builds respect LLAMA_ARG_* environment variables.
LLAMA_ARG_FLASH_ATTN=on
LLAMA_ARG_MMAP=0

# Caches
LLAMA_CACHE=/mnt/ai-models/cache/llama.cpp
HF_HOME=/mnt/ai-models/cache/hf
HUGGINGFACE_HUB_CACHE=/mnt/ai-models/cache/hf/hub
TRANSFORMERS_CACHE=/mnt/ai-models/cache/hf/transformers

# Router configuration
LLAMA_HOST=0.0.0.0
LLAMA_PORT=11434
LLAMA_MODELS_DIR=/mnt/ai-models/llm
LLAMA_MODELS_MAX=1
LLAMA_CTX=32768
LLAMA_NGL=999

# Active backend: vulkan
# Active llama.cpp version: b8693
# Binary
LLAMA_SERVER_BIN=/opt/llama.cpp/build-vulkan/bin/llama-server

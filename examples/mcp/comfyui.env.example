# Public-safe MCP environment example for ComfyUI.
# Copy and adapt for your own client or process manager.

# Use loopback if the MCP server runs on the same machine as ComfyUI.
# Otherwise point this to the real host that serves the ComfyUI HTTP API.
COMFYUI_BASE_URL=http://127.0.0.1:8188

# Conservative fallback path for the simpler MCP server.
MODEL_NAME=Juggernaut_XL_Lightning.safetensors

# Preferred Flux2 path for the richer MCP v2 server.
FLUX2_UNET=flux-2-klein-9b-Q5_K_M.gguf
FLUX2_TEXT_ENCODER=qwen_3_8b_fp4mixed.safetensors
FLUX2_VAE=flux2-vae.safetensors

# Output handling
OUTPUT_BASE=.
DEFAULT_FILENAME_PREFIX=Comfy_MCP_Gen

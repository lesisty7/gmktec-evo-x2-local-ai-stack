# Public-safe MCP environment example for a SearXNG-backed search server.

# Use loopback if the MCP server runs on the same machine as SearXNG.
# Otherwise point this to the real search endpoint.
SEARXNG_URL=http://127.0.0.1:8080/search

HTTP_TIMEOUT=12
MAX_RESULTS=8
LANGUAGE=en
CATEGORIES=general,it,dev
SAFESEARCH=1
ENGINES=
TIME_RANGE=

MIN_INTERVAL_MS=500
CACHE_TTL_SECONDS=120
CACHE_MAX_ITEMS=128

INCLUDE_RAW_DEFAULT=false
RAW_MAX_BYTES=50000
USER_AGENT=MCP-LocalSearch/1.1
